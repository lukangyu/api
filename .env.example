# ============================
# API Gateway 环境变量配置
# ============================

# 对外映射端口（宿主机端口）
HOST_PORT=8081

# SQLite 文件路径
DB_PATH=./data/gateway.db

# JWT 配置（必须修改）
JWT_SECRET=change_me_jwt_secret
JWT_EXPIRE_HOURS=24

# 默认管理员（首次启动自动创建）
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASS=changeme123

# CORS
CORS_ORIGINS=*

# 上游缓存刷新间隔（秒）
UPSTREAM_CACHE_TTL_SECONDS=30

# 日志队列
LOGGER_BUFFER_SIZE=1000
LOGGER_FLUSH_SIZE=100
